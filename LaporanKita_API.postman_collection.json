									"type": "string"
								}
							]
						},
						"method": "GET",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/laporan/saya/list",
							"host": ["{{base_url}}"],
							"path": ["api", "laporan", "saya", "list"]
						},
						"description": "## GET /api/laporan/saya/list\n\nAmbil semua laporan milik user yang sedang login. **Memerlukan Bearer Token.**\n\n**Header:** Authorization: Bearer {token}\n\n**Response:** 200 OK dengan daftar laporan milik sendiri"
					},
					"response": []
				}
			],
			"description": "Endpoint yang memerlukan autentikasi (Bearer Token)"
		}
	]
}
